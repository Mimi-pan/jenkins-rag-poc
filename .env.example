# .env.example — Copy this file to `.env` and fill in your Ollama settings.
# Never commit the real `.env` file to version control.

# Base URL of your running Ollama instance (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model used for embeddings
# Pull with: ollama pull nomic-embed-text
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
